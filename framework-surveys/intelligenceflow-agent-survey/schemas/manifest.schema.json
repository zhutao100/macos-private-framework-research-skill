{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MachOManifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "inputs",
    "binaries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "generated_by": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "binaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "name",
          "size"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "dependencies": {
            "type": "array"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MachOManifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "inputs",
    "binaries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "generated_by": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "binaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "name",
          "size"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "dependencies": {
            "oneOf": [
              {
                "type": "array"
              },
              {
                "$ref": "#/$defs/capped_lines"
              }
            ]
          },
          "defined_external_symbols": {
            "$ref": "#/$defs/capped_lines"
          },
          "focused_strings": {
            "$ref": "#/$defs/capped_lines"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "capped_lines": {
      "type": "object",
      "required": [
        "lines",
        "total_count",
        "rendered_count",
        "truncated"
      ],
      "properties": {
        "lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "total_count": {
          "type": "integer"
        },
        "rendered_count": {
          "type": "integer"
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
